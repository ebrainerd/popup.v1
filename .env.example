# ---------------------------------------------------------------------------
# PopUp environment variables
# Copy to `.env.local` and fill in. Never commit `.env.local`.
# ---------------------------------------------------------------------------

# Supabase ------------------------------------------------------------------
# Project URL, e.g. https://xxxxxxxx.supabase.co  (or http://localhost:54321 for local CLI)
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (server-only, NEVER expose to the browser). Used by webhooks/admin actions.
SUPABASE_SERVICE_ROLE_KEY=

# App -----------------------------------------------------------------------
# Public base URL of the deployed app (used for OAuth redirects & emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Discovery mode: invite_only (default) hides marketplace surfaces; marketplace re-enables Explore.
NEXT_PUBLIC_DISCOVERY_MODE=invite_only
# Environment label shown in monitoring: development | staging | production
NEXT_PUBLIC_APP_ENV=development

# Signup/login CAPTCHA (Cloudflare Turnstile) — optional. -------------------
# Set this site key AND enable Captcha (Turnstile) with the matching SECRET in
# Supabase → Authentication → Settings. Leave blank to disable the widget.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Error monitoring (Sentry) — optional; leave blank to disable. -------------
# Server DSN (falls back to the public DSN if unset).
SENTRY_DSN=
# Public DSN exposed to the browser.
NEXT_PUBLIC_SENTRY_DSN=

# Stripe (Milestone 3 — payments) ------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Platform commission taken on each sale (basis points). 900 = 9%.
PLATFORM_FEE_BPS=900
# Hours to hold funds after an order ships before releasing to the seller.
# Set to 0 for local testing to release immediately on "mark shipped".
RELEASE_DELAY_HOURS=72
# Secret protecting cron endpoints (required in production).
CRON_SECRET=

# Next.js Server Actions — set in Vercel for production builds so action IDs stay
# stable across deploys and multi-instance servers. Generate once:
#   openssl rand -base64 32
# Must be present at **build time** (not runtime-only).
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Notifications (Milestone 2) ----------------------------------------------
# Email (Resend). Leave blank to disable email notifications.
RESEND_API_KEY=
RESEND_FROM="PopUp <onboarding@resend.dev>"

# Web push (VAPID). Generate once with: npx web-push generate-vapid-keys
# Leave blank to disable web push. The public key is exposed to the browser.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@popup.app

# Native live streaming (LiveKit Cloud) --------------------------------------
# Server-only keys from LiveKit Cloud → Settings → Keys
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud
# Public WebSocket URL (same as LIVEKIT_URL) for browser clients
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
# Set to false to disable native live even when keys are present
NATIVE_LIVE_ENABLED=true
